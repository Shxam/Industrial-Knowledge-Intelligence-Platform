# Environment Configuration for IKIP (Pragya)

# Application
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
APP_DEBUG=true

# LLM Configuration (toggle between cloud/local)
LLM_PROVIDER=groq  # groq | openai | ollama | azure
GROQ_API_KEY=your_groq_api_key_here_get_from_console_groq_com
OPENAI_API_KEY=your-openai-api-key-here
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434
LLM_MODEL=llama3-70b-8192  # groq models: llama3-70b-8192, mixtral-8x7b-32768, gemma-7b-it

# Embedding Model (local by default)
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
EMBEDDING_DIMENSION=384

# Re-ranker Model
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=ikip_db
POSTGRES_USER=ikip_user
POSTGRES_PASSWORD=ikip_password_change_me

# Neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=neo4j_password_change_me

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# MinIO / S3
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=ikip-documents
MINIO_SECURE=false

# Vector Store
FAISS_INDEX_PATH=./data/faiss_index
FAISS_INDEX_TYPE=IVFFlat  # Flat | IVFFlat | HNSW

# OCR
OCR_ENGINE=paddleocr  # paddleocr | tesseract
OCR_LANG=en

# RAG Configuration
CHUNK_SIZE=512
CHUNK_OVERLAP=50
TOP_K_RETRIEVAL=10
RERANK_TOP_K=5
CONFIDENCE_THRESHOLD=0.7
ENABLE_HYBRID_SEARCH=true
ENABLE_GRAPH_AUGMENTATION=true
ENABLE_KNOWLEDGE_GRAPH=true

# Security
JWT_SECRET_KEY=your-super-secret-jwt-key-change-me-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# Guardrails
ENABLE_GUARDRAILS=true
HALLUCINATION_THRESHOLD=0.6
GROUNDEDNESS_THRESHOLD=0.7

# Monitoring & Logging
LOG_LEVEL=INFO
ENABLE_AUDIT_LOG=true

# RAGAS Evaluation
ENABLE_RAGAS_EVAL=true
RAGAS_TESTSET_SIZE=50
